# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local secrets (never commit)
.env
.env.*
!.env.example
.env.ytdlp
.env.ytdlp.example

# Local cache (game session persistence, smoke-test workspace)
.cache/
tmp/

# Runtime logs
logs/file/*.log
logs/tunnel.err.log
logs/tunnel.out.log
logs/tunnel.url

# Runtime media — git pull/deploy da serverdagi fayllar o'chmasin
src/app/site/media/photos/*
!src/app/site/media/photos/.gitkeep
!src/app/site/media/photos/no_img.png

src/app/site/media/stories/*
!src/app/site/media/stories/.gitkeep
