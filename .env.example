# ═══════════════════════════════════════════════════════════════════════════
# SpinTheBottle — .env namunasi (cp .env.example .env)
# Production domen: https://spinthebottletg.com
# ═══════════════════════════════════════════════════════════════════════════

# ── Telegram bot ───────────────────────────────────────────────────────────
BOT_TOKEN=
MAIN_ADMIN_ID=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Mini App va o'yin URL (Docker/production)
TELEGRAM_WEBAPP_URL=https://spinthebottletg.com
# Ixtiyoriy: getMe xato bo'lsa fallback; odatda BOT_TOKEN dan @username olinadi
TELEGRAM_MINIAPP_BOT=SpinbottleTgBot
TELEGRAM_MINIAPP_SLUG=spin_bottle
TELEGRAM_USE_POLLING=1
# Production webhook (polling o'rniga):
# TELEGRAM_USE_POLLING=0
# TELEGRAM_WEBHOOK_SECRET=uzun-xavfsiz-token

TELEGRAM_SUPPORT_USERNAME=SpinTheBottleSupport

# ── JWT ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-long-random-string
ALGORITHM=HS256

# ── PostgreSQL (Docker: host = postgres) ───────────────────────────────────
POSTGRES_DB=spinthebottle
POSTGRES_USER=spinthebottle
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Lokal (Docker siz): POSTGRES_HOST=localhost  POSTGRES_PORT=5434

# ── Redis (Docker: redis://redis:6379/0) ───────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Musiqa: RapidAPI (ixtiyoriy) ───────────────────────────────────────────
MUSIC_USE_RAPIDAPI_YT=1
RAPIDAPI_KEY=
YT_RAPIDAPI_HOST=yt-search-and-download-mp3.p.rapidapi.com
YT_RAPIDAPI_MP3_CACHE_TTL_SEC=21600
YT_RAPIDAPI_MP3_MAX_RETRIES=12
YT_RAPIDAPI_MP3_RETRY_SEC=3
YT_RAPIDAPI_POPULAR_QUERY=music
YT_RAPIDAPI_TIMEOUT_SEC=45

# Mahalliy musiqa API (server.json → /api_music)
MUSIC_API_OVER_LOCAL=1
MUSIC_USE_YTDLP=1
MUSIC_USE_REDIS_CACHE=1

# yt-dlp cookies (ixtiyoriy, loyiha ildizida cookies.txt yoki /api_music/setup)
# YTDLP_COOKIES_FILE=/app/cookies.txt

# ── Docker ichida Telegram Local Bot API ───────────────────────────────────
TELEGRAM_LOCAL=True
TG_API_SERVER_URL=http://api:8081

# ── Xavfsizlik (DDoS / bruteforce) ─────────────────────────────────────────
# 1 = HTTP rate limit (Redis yoki RAM). 0 = o'chirish (faqat dev)
RATE_LIMIT_ENABLED=1
# Production domen (SSL: https)
TRUSTED_HOSTS=spinthebottletg.com,www.spinthebottletg.com,localhost,127.0.0.1
# WebSocket: 10 soniyada maksimal xabar (har bir foydalanuvchi/IP)
WS_MAX_MESSAGES_PER_10S=80
